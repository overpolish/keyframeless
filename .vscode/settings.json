{
  "editor.rulers": [120],
  "[objective-c]": {
    "editor.defaultFormatter": "xaver.clang-format",
    "editor.formatOnSave": true
  },
  "C_Cpp.files.exclude": {
    "**/*.metal": true
  },
  "files.associations": {
    "*.h": "objective-c",
    "*.m": "objective-c"
  },
  "cSpell.words": [
    "autoreleasepool",
    "autoresizing",
    "blendmode",
    "CGFLOAT",
    "clipspace",
    "dealloc",
    "instancetype",
    "Keyframeless",
    "noescape",
    "nonatomic",
    "nonnull",
    "nullable",
    "objc",
    "pbxproj",
    "plist",
    "premultiplied",
    "PROAPI",
    "rasterizer",
    "readwrite",
    "Scroller",
    "simd",
    "Subview",
    "synthesize",
    "texcoord",
    "uint",
    "unichar",
    "ushort",
    "viewport",
    "xcodeproj",
    "xcworkspace"
  ]
}
